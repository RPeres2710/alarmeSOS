<script>
  $(document).ready(function() {
    let alarmActive = false;
    let acknowledged = false;
    //const audio = new Audio("/sounds/alert.wav" );
    

    //$("#btnActiveAlert").click(function(){
    //  notifyMe();
    //});


    function notifyMe() {
      if (!Notification) {
        alert('Desktop notifications not available in your browser. Try Chromium.');
        return;
      }

      

      if (Notification.permission !== 'granted'){
        Notification.requestPermission().then(function(getperm) 
      { 

          console.log('Perm granted', getperm) 

      });
      }else {
        
        var notification = new Notification('Notification title', {
        icon: 'http://cdn.sstatic.net/stackexchange/img/logos/so/so-icon.png',
        body: 'Alertas Ativos!!!',
        });
        notification.onclick = function() {
        window.open('');
        };
        audio.play();
      }
    }

    function startAlarm(){
      if(!alarmActive){
        alarmActive = true;
        $('body').addClass('alarm-flash');
        // Use Web Audio API for loud alarm sound
        try {
          const audioContext = new (window.AudioContext || window.webkitAudioContext)();
          audioContext.resume().then(() => {
            const oscillator = audioContext.createOscillator();
            const gainNode = audioContext.createGain();
            
            oscillator.connect(gainNode);
            gainNode.connect(audioContext.destination);
            
            gainNode.gain.setValueAtTime(1.0, audioContext.currentTime); // Maximum volume for loud siren
            
            oscillator.frequency.setValueAtTime(800, audioContext.currentTime);
            
            oscillator.start();
            
            // Create siren effect by changing frequency
            let direction = 1;
            const sirenInterval = setInterval(() => {
              const now = audioContext.currentTime;
              const freq = oscillator.frequency.value;
              if (freq >= 1200) direction = -1;
              if (freq <= 800) direction = 1;
              oscillator.frequency.setValueAtTime(freq + direction * 50, now);
            }, 100);
            
            window.alarmAudioContext = audioContext;
            window.alarmOscillator = oscillator;
            window.alarmSirenInterval = sirenInterval;
          });
        } catch (e) {
          // Fallback to file if Web Audio fails
          const audio = new Audio("https://cdn.freesound.org/previews/377/377125_1402315-lq.mp3");
          audio.loop = true;
          audio.volume = 1;
          audio.play();
          window.alarmAudio = audio;
        }
      }
    }

    function stopAlarm(){
      if(alarmActive){
        alarmActive = false;
        $('body').removeClass('alarm-flash');
        if(window.alarmSirenInterval){
          clearInterval(window.alarmSirenInterval);
        }
        if(window.alarmOscillator){
          window.alarmOscillator.stop();
        }
        if(window.alarmAudioContext){
          window.alarmAudioContext.close();
        }
        if(window.alarmAudio){
          window.alarmAudio.pause();
          window.alarmAudio.currentTime = 0;
        }
      }
    }

    function getAlerts() {
      setTimeout(function() {
          
          $.ajax({
              url: 'https://movisos-admin.movisafe-americalatina.com/index.php/admin/ajaxActiveAlerts/',
              type: 'GET',
              success: function(data) {
                  if(data != ''){
                    $("#activeAlertsDetail").html(data);
                    if(!$("#btn-alertlist").hasClass("bg-danger")){
                      $("#activeAlerts").modal('show');
                      $("#btn-alertlist").addClass("bg-danger");
                      if(!acknowledged){
                        startAlarm();
                      }
                    }
                  }else{
                    $("#btn-alertlist").removeClass("bg-danger");
                    $("#activeAlerts").modal('hide');
                    stopAlarm();
                    acknowledged = false;
                  }
              },
              error: function (request, status, error) {
                  console.log(request.responseText);
              },
              complete: getAlerts,
              timeout: 10000
          }) //, 5000  <-- oops.
      }, 10000); // <-- should be here instead
    };

    $('#acknowledgeBtn').click(function(){
      acknowledged = true;
      stopAlarm();
      $("#activeAlerts").modal('hide');
    });

    // Test button to activate alarm immediately after user interaction
    $('#testAlarmBtn').click(function() {
      startAlarm();
      $("#activeAlerts").modal('show');
      $("#activeAlertsDetail").html('<p>Alerta de teste ativado! Clique em "Reconhecer Alerta" para parar.</p>');
    });

    getAlerts();
  });
